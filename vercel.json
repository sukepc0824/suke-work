{
  "rewrites": [
    {
      "source": "/(.*\\.css)",
      "destination": "/$1"
    },
    {
      "source": "/data/(.*)",
      "destination": "/data/$1"
    },
    {
      "source": "/lang.js",
      "destination": "/lang.js"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}